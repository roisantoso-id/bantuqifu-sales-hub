generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id                      String                    @id @default(cuid())
  code                    String                    @unique
  name                    String
  site                    String                    @default("ID")
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  wecomCorpId             String?                   @unique
  actionLogs              ActionLog[]
  bank_transactions       bank_transactions[]
  commission_records      commission_records[]
  customerFollowups       CustomerFollowup[]
  customers               Customer[]
  delivery_items          delivery_items[]
  departments             departments[]
  dict_product_categories dict_product_categories[]
  import_batches          import_batches[]
  interactions            Interaction[]
  leads                   Lead[]
  opportunities           Opportunity[]
  products                Product[]
  users                   UserOrganization[]
  vendors                 vendors[]
  wecom_bots              wecom_bots[]

  @@map("organizations")
}

model Role {
  id          String             @id @default(cuid())
  code        String             @unique
  name        String
  createdAt   DateTime           @default(now())
  wecomTagId  Int?
  nameId      String?
  permissions RolePermission[]
  users       UserOrganization[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  module      String
  description String?
  createdAt   DateTime         @default(now())
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id                                                                 String                 @id
  email                                                              String                 @unique
  name                                                               String
  isActive                                                           Boolean                @default(true)
  createdAt                                                          DateTime               @default(now())
  updatedAt                                                          DateTime               @updatedAt
  departmentId                                                       String?
  wecomUserId                                                        String?                @unique
  actionLogs                                                         ActionLog[]
  bank_transactions                                                  bank_transactions[]
  commission_records                                                 commission_records[]
  followups                                                          CustomerFollowup[]     @relation("FollowupOperator")
  delivery_assignments_delivery_assignments_assignedByIdTousers_auth delivery_assignments[] @relation("delivery_assignments_assignedByIdTousers_auth")
  delivery_assignments_delivery_assignments_executorIdTousers_auth   delivery_assignments[] @relation("delivery_assignments_executorIdTousers_auth")
  delivery_items_delivery_items_executorIdTousers_auth               delivery_items[]       @relation("delivery_items_executorIdTousers_auth")
  delivery_items_delivery_items_pmIdTousers_auth                     delivery_items[]       @relation("delivery_items_pmIdTousers_auth")
  delivery_records                                                   delivery_records[]
  import_batches                                                     import_batches[]
  interactions                                                       Interaction[]          @relation("InteractionOperator")
  leads                                                              Lead[]                 @relation("LeadAssignee")
  opportunities                                                      Opportunity[]          @relation("OpportunityAssignee")
  organizations                                                      UserOrganization[]
  departments                                                        departments?           @relation(fields: [departmentId], references: [id])

  @@map("users_auth")
}

model UserOrganization {
  userId         String
  organizationId String
  roleId         String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role         @relation(fields: [roleId], references: [id])
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, organizationId])
  @@map("user_organizations")
}

model Lead {
  id                     String         @id @default(cuid())
  organizationId         String
  leadCode               String         @unique
  wechatName             String
  phone                  String?
  source                 LeadSource
  category               LeadCategory?
  budgetMin              Float?
  budgetMax              Float?
  budgetCurrency         String         @default("CNY")
  urgency                LeadUrgency    @default(MEDIUM)
  initialIntent          String
  assigneeId             String?
  nextFollowDate         DateTime?
  lastActionAt           DateTime?
  status                 LeadStatus     @default(new)
  discardedAt            DateTime?
  discardReason          DiscardReason?
  discardedById          String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  notes                  String?
  convertedOpportunityId String?        @unique
  customerId             String?
  wechatGroupId          Int?
  wechatGroupName        String?
  interactions           Interaction[]
  assignee               User?          @relation("LeadAssignee", fields: [assigneeId], references: [id])
  customer               Customer?      @relation(fields: [customerId], references: [id])
  organization           Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  convertedOpportunity   Opportunity?   @relation("LeadToOpportunity")

  @@unique([organizationId, leadCode])
  @@index([organizationId])
  @@index([status])
  @@index([assigneeId])
  @@index([discardedAt])
  @@map("leads")
}

model Customer {
  id              String                      @id @default(cuid())
  organizationId  String
  customerId      String                      @unique
  customerName    String
  passportNo      String?
  phone           String?
  email           String?
  wechat          String?
  level           CustomerLevel               @default(L5)
  levelDictId     String?
  industryId      String?
  isLocked        Boolean                     @default(false)
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  customerCode    String?                     @unique
  contacts        CustomerContact[]
  followups       CustomerFollowup[]
  industry        Industry?                   @relation(fields: [industryId], references: [id])
  levelDict       CustomerLevelDict?          @relation(fields: [levelDictId], references: [id])
  organization    Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  chinaEntities   DomesticEntityAssociation[]
  foreignEntities ForeignCompanyEntity[]
  interactions    Interaction[]
  leads           Lead[]
  opportunities   Opportunity[]

  @@unique([organizationId, customerId])
  @@index([organizationId])
  @@index([levelDictId])
  @@index([industryId])
  @@index([customerCode])
  @@map("customers")
}

model CustomerContact {
  id          String   @id @default(cuid())
  customerId  String
  contactName String
  position    String?
  phone       String?
  email       String?
  wechat      String?
  isPrimary   Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_contacts")
}

model CustomerFollowup {
  id             String                       @id @default(cuid())
  organizationId String
  customerId     String
  operatorId     String?
  followupType   String                       @default("general")
  content        String
  nextAction     String?
  nextActionDate DateTime?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  attachments    CustomerFollowupAttachment[]
  customer       Customer                     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  operator       User?                        @relation("FollowupOperator", fields: [operatorId], references: [id])
  organization   Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([customerId])
  @@index([operatorId])
  @@map("customer_followups")
}

model CustomerFollowupAttachment {
  id         String           @id @default(cuid())
  followupId String
  fileName   String
  fileSize   Int
  fileUrl    String
  uploadedAt DateTime         @default(now())
  followup   CustomerFollowup @relation(fields: [followupId], references: [id], onDelete: Cascade)

  @@map("customer_followup_attachments")
}

model DomesticEntity {
  id                   String                      @id @default(cuid())
  creditCode           String                      @unique
  companyName          String
  legalPerson          String?
  regCapital           String?
  businessScope        String?
  status               ChinaEntityStatus
  industry             String?
  foundedDate          DateTime?
  registrationLocation String?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  associations         DomesticEntityAssociation[]

  @@map("domestic_entities")
}

model DomesticEntityAssociation {
  id            String         @id @default(cuid())
  customerId    String
  chinaEntityId String
  businessMatch String         @default("medium")
  riskLevel     String         @default("medium")
  notes         String?
  associatedAt  DateTime       @default(now())
  chinaEntity   DomesticEntity @relation(fields: [chinaEntityId], references: [id])
  customer      Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, chinaEntityId])
  @@map("domestic_entity_associations")
}

model ForeignCompanyEntity {
  id                 String   @id @default(cuid())
  customerId         String
  companyName        String
  country            String
  registrationNumber String?
  legalPerson        String?
  regCapital         String?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  customer           Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("foreign_company_entities")
}

model Product {
  id                      String                    @id @default(cuid())
  organizationId          String
  productCode             String                    @unique
  name                    String
  category                String
  description             String?
  difficulty              Int                       @default(1)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  isExpertMode            Boolean                   @default(false)
  sla                     Int?
  expertTag               String[]                  @default([])
  categoryId              String?
  materials               MaterialItem[]
  material_items_template material_items_template[]
  opportunity_items       opportunity_items[]
  p2Data                  OpportunityP2Data[]
  p3Data                  OpportunityP3Data[]
  product_prices          product_prices[]
  dict_product_categories dict_product_categories?  @relation(fields: [categoryId], references: [id])
  organization            Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  progressPoints          ProgressPoint[]
  vendor_products         vendor_products[]

  @@unique([organizationId, productCode])
  @@index([organizationId])
  @@map("products")
}

model Opportunity {
  id                   String                @id @default(cuid())
  organizationId       String
  opportunityCode      String                @unique
  customerId           String
  stageId              String                @default("P1")
  status               OpportunityStatus     @default(active)
  serviceType          ServiceType
  serviceTypeLabel     String
  estimatedAmount      Float
  currency             String                @default("IDR")
  requirements         String?
  notes                String?
  destination          String?
  travelDate           DateTime?
  assigneeId           String
  wechatGroupId        Int?
  wechatGroupName      String?
  pinnedByUsers        String[]              @default([])
  expectedCloseDate    DateTime?
  actualCloseDate      DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  convertedFromLeadId  String?               @unique
  actionLogs           ActionLog[]
  delivery_assignments delivery_assignments?
  delivery_items       delivery_items[]
  interactions         Interaction[]
  assignee             User                  @relation("OpportunityAssignee", fields: [assigneeId], references: [id])
  convertedFromLead    Lead?                 @relation("LeadToOpportunity", fields: [convertedFromLeadId], references: [id])
  customer             Customer              @relation(fields: [customerId], references: [id])
  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunity_items    opportunity_items[]
  p2Data               OpportunityP2Data[]
  p3Data               OpportunityP3Data[]
  p4Data               OpportunityP4Data?
  p5Data               OpportunityP5Data?
  p6Data               OpportunityP6Data?
  p7Data               OpportunityP7Data?
  p8Data               OpportunityP8Data?

  @@unique([organizationId, opportunityCode])
  @@index([organizationId])
  @@index([customerId])
  @@index([stageId])
  @@index([assigneeId])
  @@map("opportunities")
}

model OpportunityP2Data {
  id            String      @id @default(cuid())
  opportunityId String
  productId     String
  cycle         String?
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  product       Product     @relation(fields: [productId], references: [id])

  @@map("opportunity_p2_data")
}

model OpportunityP3Data {
  id               String      @id @default(cuid())
  opportunityId    String
  productId        String
  quantity         Int         @default(1)
  lockedPrice      Float
  currency         String
  recommendedPrice Float?
  costFloor        Float?
  profitMargin     Float?
  approvalStatus   String      @default("auto-approved")
  approvedAt       DateTime?
  approvedById     String?
  opportunity      Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  product          Product     @relation(fields: [productId], references: [id])

  @@map("opportunity_p3_data")
}

model OpportunityP4Data {
  id                String      @id @default(cuid())
  opportunityId     String      @unique
  contractFileUrl   String?
  contractFileName  String?
  contractFileSize  Int?
  contractStatus    String      @default("pending")
  uploadedAt        DateTime?
  notes             String?
  sealVisible       Boolean     @default(false)
  signatureComplete Boolean     @default(false)
  qualityClear      Boolean     @default(false)
  opportunity       Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@map("opportunity_p4_data")
}

model OpportunityP5Data {
  id                String      @id @default(cuid())
  opportunityId     String      @unique
  bankAccount       String?
  bankName          String?
  accountHolder     String?
  swiftCode         String?
  dueAmount         Float
  receivedAmount    Float       @default(0)
  receiptFileUrl    String?
  receiptFileName   String?
  receiptUploadedAt DateTime?
  receiptUploadedBy String?
  paymentStatus     String      @default("pending")
  rejectionReason   String?
  confirmedAt       DateTime?
  confirmedById     String?
  opportunity       Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@map("opportunity_p5_data")
}

model OpportunityP6Data {
  id            String         @id @default(cuid())
  opportunityId String         @unique
  lastUpdatedAt DateTime?
  materials     MaterialItem[]
  opportunity   Opportunity    @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@map("opportunity_p6_data")
}

model MaterialItem {
  id              String            @id @default(cuid())
  p6DataId        String
  productId       String?
  name            String
  requirement     String?
  status          String            @default("missing")
  fileUrl         String?
  fileName        String?
  fileSize        Int?
  ocrStatus       String            @default("pending")
  rejectionReason String?
  uploadedAt      DateTime?
  uploadedBy      String?
  approvedAt      DateTime?
  approvedBy      String?
  deliveryItemId  String?
  delivery_items  delivery_items?   @relation(fields: [deliveryItemId], references: [id], onDelete: Cascade)
  p6Data          OpportunityP6Data @relation(fields: [p6DataId], references: [id], onDelete: Cascade)
  product         Product?          @relation(fields: [productId], references: [id])

  @@index([deliveryItemId])
  @@map("material_items")
}

model OpportunityP7Data {
  id                String          @id @default(cuid())
  opportunityId     String          @unique
  finalDocumentUrl  String?
  finalDocumentName String?
  deliveryStatus    String          @default("in_transit")
  deliveredAt       DateTime?
  notes             String?
  completedAt       DateTime?
  opportunity       Opportunity     @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  progressPoints    ProgressPoint[]

  @@map("opportunity_p7_data")
}

model ProgressPoint {
  id        String            @id @default(cuid())
  p7DataId  String
  productId String?
  label     String
  status    String            @default("pending")
  timestamp DateTime?
  p7Data    OpportunityP7Data @relation(fields: [p7DataId], references: [id], onDelete: Cascade)
  product   Product?          @relation(fields: [productId], references: [id])

  @@map("progress_points")
}

model OpportunityP8Data {
  id                String        @id @default(cuid())
  opportunityId     String        @unique
  totalAmount       Float
  paidAmount        Float         @default(0)
  balanceDue        Float
  balanceReceiptUrl String?
  balanceReceivedAt DateTime?
  balanceStatus     String        @default("pending")
  totalRefund       Float         @default(0)
  totalExpense      Float         @default(0)
  netBalance        Float
  profitMargin      Float?
  settledAt         DateTime?
  settledById       String?
  archived          Boolean       @default(false)
  notes             String?
  expenses          ExpenseItem[]
  opportunity       Opportunity   @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  refunds           RefundItem[]

  @@map("opportunity_p8_data")
}

model RefundItem {
  id             String            @id @default(cuid())
  p8DataId       String
  serviceId      String
  serviceName    String
  originalAmount Float
  refundedAmount Float
  reason         String
  refundedAt     DateTime?
  refundedBy     String?
  receiptUrl     String?
  p8Data         OpportunityP8Data @relation(fields: [p8DataId], references: [id], onDelete: Cascade)

  @@map("refund_items")
}

model ExpenseItem {
  id              String            @id @default(cuid())
  p8DataId        String
  description     String
  amount          Float
  category        String            @default("other")
  receiptUrl      String?
  receiptFileName String?
  createdBy       String
  createdAt       DateTime          @default(now())
  approvedBy      String?
  approvedAt      DateTime?
  vendorId        String?
  paymentStatus   String            @default("UNPAID")
  paymentDate     DateTime?
  p8Data          OpportunityP8Data @relation(fields: [p8DataId], references: [id], onDelete: Cascade)
  vendors         vendors?          @relation(fields: [vendorId], references: [id])

  @@map("expense_items")
}

model ActionLog {
  id             String                @id @default(cuid())
  organizationId String
  opportunityId  String
  operatorId     String
  stageId        String?
  actionType     ActionType
  actionLabel    String
  remark         String?
  timestamp      DateTime              @default(now())
  attachments    ActionLogAttachment[]
  operator       User                  @relation(fields: [operatorId], references: [id])
  opportunity    Opportunity           @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([opportunityId])
  @@index([operatorId])
  @@index([timestamp])
  @@map("action_logs")
}

model ActionLogAttachment {
  id          String    @id @default(cuid())
  actionLogId String
  fileName    String
  fileSize    Int
  fileUrl     String
  uploadedAt  DateTime  @default(now())
  actionLog   ActionLog @relation(fields: [actionLogId], references: [id], onDelete: Cascade)

  @@map("action_log_attachments")
}

model Industry {
  id        String     @id @default(cuid())
  code      String     @unique
  nameZh    String
  nameId    String?
  nameEn    String?
  parentId  String?
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  customers Customer[]
  parent    Industry?  @relation("IndustryHierarchy", fields: [parentId], references: [id])
  children  Industry[] @relation("IndustryHierarchy")

  @@index([parentId])
  @@index([sortOrder])
  @@map("dict_industries")
}

model CustomerLevelDict {
  id          String     @id @default(cuid())
  code        String     @unique
  nameZh      String
  nameId      String?
  nameEn      String?
  weight      Int        @default(1)
  description String?
  colorClass  String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  customers   Customer[]

  @@index([sortOrder])
  @@map("dict_customer_levels")
}

model WechatGroupSequence {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  @@map("wechat_group_sequences")
}

model SystemCounter {
  id        String   @id
  sequence  Int      @default(0)
  updatedAt DateTime @updatedAt

  @@map("system_counters")
}

model Interaction {
  id             String                  @id @default(cuid())
  organizationId String
  customerId     String
  leadId         String?
  opportunityId  String?
  operatorId     String?
  type           InteractionType         @default(NOTE)
  content        String
  nextAction     String?
  nextActionDate DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  attachments    InteractionAttachment[]
  customer       Customer                @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lead           Lead?                   @relation(fields: [leadId], references: [id])
  operator       User?                   @relation("InteractionOperator", fields: [operatorId], references: [id])
  opportunity    Opportunity?            @relation(fields: [opportunityId], references: [id])
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([customerId])
  @@index([leadId])
  @@index([opportunityId])
  @@index([operatorId])
  @@map("interactions")
}

model InteractionAttachment {
  id            String      @id @default(cuid())
  interactionId String
  fileName      String
  fileUrl       String
  fileSize      Int
  createdAt     DateTime    @default(now())
  interaction   Interaction @relation(fields: [interactionId], references: [id], onDelete: Cascade)

  @@map("interaction_attachments")
}

model app_settings {
  id                      String   @id @default("singleton")
  email_account           String   @default("admin@bantuqifu.com")
  email_password          String?
  email_filter            String   @default("@imigrasi.go.id")
  email_frequency_minutes Int      @default(5)
  wecom_webhook_url       String?
  voice_bot_api_key       String?
  voice_call_time         String   @default("working-hours")
  voice_receiver          String   @default("wangshuo")
  updatedAt               DateTime
}

model bank_transactions {
  id              String          @id
  organizationId  String
  bankName        String
  accountName     String?
  accountNumber   String?
  currency        String
  transactionDate DateTime
  description     String
  amount          Float
  type            TransactionType
  balance         Float?
  reference       String?
  rawText         String?
  importBatchId   String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  uploadedById    String?
  import_batches  import_batches? @relation(fields: [importBatchId], references: [id])
  organizations   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users_auth      User?           @relation(fields: [uploadedById], references: [id])

  @@index([bankName])
  @@index([importBatchId])
  @@index([organizationId])
  @@index([transactionDate])
  @@index([uploadedById])
}

model delivery_assignments {
  id                                                       String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  opportunityId                                            String      @unique
  organizationId                                           String
  executorId                                               String
  assignedById                                             String
  notes                                                    String?
  status                                                   String      @default("active")
  assignedAt                                               DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt                                                DateTime    @default(now()) @db.Timestamptz(6)
  users_auth_delivery_assignments_assignedByIdTousers_auth User        @relation("delivery_assignments_assignedByIdTousers_auth", fields: [assignedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_auth_delivery_assignments_executorIdTousers_auth   User        @relation("delivery_assignments_executorIdTousers_auth", fields: [executorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  opportunities                                            Opportunity @relation(fields: [opportunityId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([executorId], map: "idx_delivery_assignments_executor")
  @@index([organizationId], map: "idx_delivery_assignments_org")
}

model departments {
  id                 String               @id
  organizationId     String
  name               String
  wecomDeptId        Int?
  parentId           String?
  sortOrder          Int                  @default(0)
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  commission_records commission_records[]
  delivery_items     delivery_items[]
  organizations      Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departments        departments?         @relation("departmentsTodepartments", fields: [parentId], references: [id])
  other_departments  departments[]        @relation("departmentsTodepartments")
  users_auth         User[]

  @@unique([organizationId, wecomDeptId])
  @@index([organizationId])
  @@index([parentId])
}

model email_process_logs {
  id            String    @id
  messageId     String
  pdfKey        String
  pdfFilename   String
  status        String    @default("PENDING")
  extractedData Json?
  errorMessage  String?
  processedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime

  @@index([createdAt])
  @@index([messageId])
  @@index([status])
}

model import_batches {
  id                String              @id
  organizationId    String
  bankName          String
  currency          String
  fileName          String
  fileUrl           String
  rowCount          Int
  createdAt         DateTime            @default(now())
  uploadedById      String?
  bank_transactions bank_transactions[]
  organizations     Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users_auth        User?               @relation(fields: [uploadedById], references: [id])

  @@index([organizationId])
  @@index([uploadedById])
}

model material_items_template {
  id          String   @id
  productId   String
  name        String
  nameId      String?
  isRequired  Boolean  @default(true)
  docType     DocType  @default(IMAGE)
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  products    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model product_prices {
  id              String    @id
  productId       String
  costPriceIdr    Float
  costPriceCny    Float
  partnerPriceIdr Float?
  partnerPriceCny Float?
  retailPriceIdr  Float
  retailPriceCny  Float?
  isCurrent       Boolean   @default(true)
  effectiveDate   DateTime  @default(now())
  expiryDate      DateTime?
  createdAt       DateTime  @default(now())
  products        Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([isCurrent])
  @@index([productId])
}

model reminders {
  id              String       @id
  visa_id         String
  customer_name   String
  passport_no     String
  visa_type       String
  expiry_date     DateTime
  days_left       Int
  stage           String
  status          String
  last_sent_at    DateTime?
  retry_count     Int          @default(0)
  is_acknowledged Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime
  visa_records    visa_records @relation(fields: [visa_id], references: [id], onDelete: Cascade)

  @@index([days_left, status])
  @@index([visa_id])
}

model system_logs {
  id        String   @id
  timestamp DateTime @default(now())
  level     String
  module    String
  message   String
  user      String?
  metadata  Json?

  @@index([module])
  @@index([timestamp, level])
}

model vendor_products {
  id         String   @id
  vendorId   String
  productId  String
  costPrice  Float?
  currency   String   @default("IDR")
  serviceSla String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  products   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendors    vendors  @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, productId])
  @@index([productId])
}

model vendors {
  id              String            @id
  organizationId  String
  vendorCode      String            @unique
  vendorName      String
  category        String?
  contactName     String?
  phone           String?
  email           String?
  wechat          String?
  bankName        String?
  bankAccount     String?
  accountHolder   String?
  taxId           String?
  status          VendorStatus      @default(ACTIVE)
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  expense_items   ExpenseItem[]
  vendor_products vendor_products[]
  organizations   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, vendorCode])
  @@index([category])
  @@index([organizationId])
}

model visa_customers {
  id               String         @id
  passport_no      String         @unique
  name             String
  phone            String?
  whatsapp         String?
  place_of_birth   String?
  passport_expiry  DateTime?
  nationality      String?
  gender           String?
  address          String?
  activity         String?
  occupation       String?
  guarantor        String?
  ministry_name    String?
  issuing_office   String?
  issuing_date     DateTime?
  issuing_location String?
  office_address   String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime
  visa_records     visa_records[]

  @@index([passport_no])
}

model visa_records {
  id               String         @id
  customerId       String
  visaTypeCode     String
  passport_no      String
  expiry_date      DateTime
  is_urgent        Boolean        @default(false)
  reminder_enabled Boolean        @default(false)
  entry_date       DateTime?
  port_of_entry    String?
  file_url         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime
  reminders        reminders[]
  visa_customers   visa_customers @relation(fields: [customerId], references: [id], onDelete: Cascade)
  visa_types       visa_types     @relation(fields: [visaTypeCode], references: [code])

  @@unique([customerId, visaTypeCode, expiry_date])
  @@index([customerId])
  @@index([expiry_date])
  @@index([visaTypeCode])
}

model visa_types {
  id            String         @id
  code          String         @unique
  nameZh        String
  nameId        String
  requiresEntry Boolean        @default(false)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime
  visa_records  visa_records[]

  @@index([code])
  @@index([isActive])
}

model wecom_bots {
  id             String       @id
  organizationId String
  name           String
  webhookUrl     String
  isActive       Boolean      @default(true)
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  businessModule String?
  triggerScenes  String[]     @default([])
  organizations  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model commission_records {
  id             String       @id
  organizationId String
  departmentId   String?
  userId         String
  roleType       String
  sourceId       String
  amount         Decimal      @db.Decimal(12, 2)
  status         String       @default("PENDING")
  settlementDate DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  departments    departments? @relation(fields: [departmentId], references: [id])
  organizations  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users_auth     User         @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([userId])
}

model delivery_items {
  id                                               String             @id
  organizationId                                   String
  departmentId                                     String?
  opportunityId                                    String
  opportunityItemId                                String             @unique
  executorId                                       String?
  pmId                                             String?
  status                                           String             @default("TODO")
  deadline                                         DateTime?
  createdAt                                        DateTime           @default(now())
  updatedAt                                        DateTime
  departments                                      departments?       @relation(fields: [departmentId], references: [id])
  users_auth_delivery_items_executorIdTousers_auth User?              @relation("delivery_items_executorIdTousers_auth", fields: [executorId], references: [id])
  opportunities                                    Opportunity        @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  opportunity_items                                opportunity_items  @relation(fields: [opportunityItemId], references: [id], onDelete: Cascade)
  organizations                                    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users_auth_delivery_items_pmIdTousers_auth       User?              @relation("delivery_items_pmIdTousers_auth", fields: [pmId], references: [id])
  delivery_records                                 delivery_records[]
  material_items                                   MaterialItem[]

  @@index([departmentId])
  @@index([status])
}

model delivery_records {
  id             String         @id
  deliveryItemId String
  userId         String
  actionType     String
  content        String?
  attachmentUrl  String?
  createdAt      DateTime       @default(now())
  delivery_items delivery_items @relation(fields: [deliveryItemId], references: [id], onDelete: Cascade)
  users_auth     User           @relation(fields: [userId], references: [id])

  @@index([deliveryItemId])
}

model opportunity_items {
  id               String          @id
  organizationId   String
  opportunityId    String
  productId        String
  targetName       String?
  unitPrice        Float
  currency         String          @default("IDR")
  costFloor        Float?
  profitMargin     Float?
  settlementStatus String          @default("UNSETTLED")
  salesRemarks     String?
  deliveryRemarks  String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime
  delivery_items   delivery_items?
  opportunities    Opportunity     @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  products         Product         @relation(fields: [productId], references: [id])

  @@index([opportunityId])
  @@index([organizationId])
  @@index([productId])
}

model dict_product_categories {
  id             String       @id
  organizationId String
  code           String
  nameZh         String
  nameId         String?
  nameEn         String?
  description    String?
  sortOrder      Int          @default(0)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now())
  organizations  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "dict_product_categories_org_fkey")
  products       Product[]

  @@unique([organizationId, code], map: "dict_product_categories_code_key")
}

enum LeadSource {
  wechat
  referral
  facebook
  website
  cold_outreach
}

enum LeadStatus {
  new
  contacted
  no_interest
  ready_for_opportunity
  discarded
  public_pool
  converted
}

enum LeadUrgency {
  HIGH
  MEDIUM
  LOW
}

enum LeadCategory {
  VISA
  COMPANY_REGISTRATION
  FINANCIAL_SERVICES
  PERMIT_SERVICES
  TAX_SERVICES
}

enum DiscardReason {
  NO_CONTACT
  MISMATCH_NEEDS
  LIMITED_SALES_CAPABILITY
  OTHER
  RETURN_TO_POOL
}

enum CustomerLevel {
  L2
  L3
  L4
  L5
  L6
}

enum ChinaEntityStatus {
  OPERATING
  REVOKED
  CANCELLED
}

enum ServiceType {
  VISA
  COMPANY_REGISTRATION
  FACTORY_SETUP
  TAX_SERVICES
  PERMIT_SERVICES
  FINANCIAL_SERVICES
  IMMIGRATION
  OTHER
}

enum OpportunityStatus {
  active
  won
  lost
}

enum ActionType {
  FORM
  MATCH
  STAGE_CHANGE
  NOTE
  QUOTE
  CREATE
}

enum InteractionType {
  NOTE
  CALL
  VISIT
  MEETING
  EMAIL
  STAGE_CHANGE
  SYSTEM
}

enum DocType {
  IMAGE
  PDF
  FILETEXT
  FILE
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum VendorStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}
